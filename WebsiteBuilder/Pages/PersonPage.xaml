<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.PersonPage"
             Title="Person">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="Person Info" FontSize="22" FontAttributes="Bold" />
            <Label Text="Basic identity displayed across the site." Opacity="0.6" />

            <!-- Load / Save Bar -->
            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" BackgroundColor="Green" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Name" FontAttributes="Bold" />
            <Entry x:Name="NameEntry" Placeholder="Full Name" />

            <Label Text="Title" FontAttributes="Bold" />
            <Entry x:Name="TitleEntry" Placeholder="Job Title" />

            <Label Text="LinkedIn URL" FontAttributes="Bold" />
            <Entry x:Name="LinkedinEntry" Placeholder="https://linkedin.com/in/..." Keyboard="Url" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
