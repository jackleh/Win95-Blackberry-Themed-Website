<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.PersonPage"
             Title="Person">
    <Grid RowDefinitions="Auto,*">
        <!-- Divider between the locked flyout and the content. -->
        <BoxView Grid.RowSpan="2" WidthRequest="2" HorizontalOptions="Start" Color="{StaticResource Win95Shadow}" />
        <VerticalStackLayout Grid.Row="0" Padding="16,18" Spacing="0" BackgroundColor="{StaticResource Win95Navy}">
            <Label Text="Person" Style="{StaticResource NavTitle}" />
            <Label Text="Basic identity displayed across the site." Style="{StaticResource NavSubtitle}" />
        </VerticalStackLayout>
        <ScrollView Grid.Row="1" Padding="20">
        <VerticalStackLayout Spacing="16">

            <!-- Load / Save Bar -->
            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Win95Shadow}" />

            <Label Text="Name" FontAttributes="Bold" />
            <Entry x:Name="NameEntry" Placeholder="Full Name" />

            <Label Text="Title" FontAttributes="Bold" />
            <Entry x:Name="TitleEntry" Placeholder="Job Title" />

            <Label Text="LinkedIn URL" FontAttributes="Bold" />
            <Entry x:Name="LinkedinEntry" Placeholder="https://linkedin.com/in/..." Keyboard="Url" />

        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
