<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.SiteConfigPage"
             Title="Site Config">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="Site Configuration" FontSize="22" FontAttributes="Bold" />
            <Label Text="Win95 theme settings, video URLs, OS branding, and media assets." Opacity="0.6" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" BackgroundColor="Green" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- General -->
            <Label Text="General" FontSize="18" FontAttributes="Bold" />

            <Label Text="Site Title" FontAttributes="Bold" />
            <Entry x:Name="SiteTitleEntry" Placeholder=".NET Developer - Name" />

            <HorizontalStackLayout Spacing="8">
                <Label Text="Win95 Enabled" FontAttributes="Bold" VerticalOptions="Center" />
                <Switch x:Name="Win95EnabledSwitch" />
            </HorizontalStackLayout>

            <Label Text="Donate Link" FontAttributes="Bold" />
            <Entry x:Name="DonateLinkEntry" Placeholder="https://ko-fi.com/username" Keyboard="Url" />

            <BoxView HeightRequest="2" Color="{StaticResource Primary}" />

            <!-- OS Branding -->
            <Label Text="OS Branding" FontSize="18" FontAttributes="Bold" />

            <Label Text="OS Name" FontAttributes="Bold" />
            <Entry x:Name="OsNameEntry" Placeholder="Copland OS" />

            <Label Text="OS Version" FontAttributes="Bold" />
            <Entry x:Name="OsVersionEntry" Placeholder="Copland OS Enterprise [Version 8.00.001]" />

            <Label Text="OS Copyright" FontAttributes="Bold" />
            <Entry x:Name="OsCopyrightEntry" Placeholder="(C) Copyright ..." />

            <Label Text="OS Directory Name" FontAttributes="Bold" />
            <Entry x:Name="OsDirNameEntry" Placeholder="COPLAND" />

            <BoxView HeightRequest="2" Color="{StaticResource Primary}" />

            <!-- Application Names -->
            <Label Text="Application Names" FontSize="18" FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <Label Text="Paint Exe Name" FontAttributes="Bold" Grid.Row="0" Grid.Column="0" />
                <Entry x:Name="PaintExeEntry" Placeholder="paint.exe" Grid.Row="0" Grid.Column="1" />

                <Label Text="Paint Display Name" FontAttributes="Bold" Grid.Row="1" Grid.Column="0" />
                <Entry x:Name="PaintDisplayEntry" Placeholder="Paint" Grid.Row="1" Grid.Column="1" />

                <Label Text="Notepad Exe Name" FontAttributes="Bold" Grid.Row="2" Grid.Column="0" />
                <Entry x:Name="NotepadExeEntry" Placeholder="notepad.exe" Grid.Row="2" Grid.Column="1" />

                <Label Text="Notepad Display Name" FontAttributes="Bold" Grid.Row="3" Grid.Column="0" />
                <Entry x:Name="NotepadDisplayEntry" Placeholder="Notepad" Grid.Row="3" Grid.Column="1" />

                <Label Text="CMD Exe Name" FontAttributes="Bold" Grid.Row="4" Grid.Column="0" />
                <Entry x:Name="CmdExeEntry" Placeholder="cmd.exe" Grid.Row="4" Grid.Column="1" />

                <Label Text="Resume File Name" FontAttributes="Bold" Grid.Row="5" Grid.Column="0" />
                <Entry x:Name="ResumeFileEntry" Placeholder="resume.md" Grid.Row="5" Grid.Column="1" />

                <Label Text="Projects File Name" FontAttributes="Bold" Grid.Row="6" Grid.Column="0" />
                <Entry x:Name="ProjectsFileEntry" Placeholder="projects.txt" Grid.Row="6" Grid.Column="1" />
            </Grid>

            <Label Text="Contact File Name" FontAttributes="Bold" />
            <Entry x:Name="ContactFileEntry" Placeholder="contact.txt" />

            <BoxView HeightRequest="2" Color="{StaticResource Primary}" />

            <!-- Videos -->
            <Label Text="Videos" FontSize="18" FontAttributes="Bold" />
            <Label Text="Enter URLs or use the file picker to copy video files into the website media folder." Opacity="0.6" />

            <Label Text="Video 1 URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="Video1UrlEntry" Placeholder="https://... or media/video.mp4" HorizontalOptions="FillAndExpand" Keyboard="Url" />
                <Button Text="Browse..." Clicked="OnPickVideo1" />
            </HorizontalStackLayout>
            <Label Text="Video 1 Title" FontAttributes="Bold" />
            <Entry x:Name="Video1TitleEntry" Placeholder="video_name.mp4" />

            <Label Text="Video 2 URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="Video2UrlEntry" Placeholder="https://... or media/video.mp4" HorizontalOptions="FillAndExpand" Keyboard="Url" />
                <Button Text="Browse..." Clicked="OnPickVideo2" />
            </HorizontalStackLayout>
            <Label Text="Video 2 Title" FontAttributes="Bold" />
            <Entry x:Name="Video2TitleEntry" Placeholder="video_name.mp4" />

            <Label Text="Video 3 URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="Video3UrlEntry" Placeholder="https://... or media/video.mp4" HorizontalOptions="FillAndExpand" Keyboard="Url" />
                <Button Text="Browse..." Clicked="OnPickVideo3" />
            </HorizontalStackLayout>
            <Label Text="Video 3 Title" FontAttributes="Bold" />
            <Entry x:Name="Video3TitleEntry" Placeholder="video_name.mp4" />

            <BoxView HeightRequest="2" Color="{StaticResource Primary}" />

            <!-- Images -->
            <Label Text="Images" FontSize="18" FontAttributes="Bold" />

            <Label Text="Desktop Picture URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="DesktopPicEntry" Placeholder="media/image/wallpaper.png" HorizontalOptions="FillAndExpand" />
                <Button Text="Browse Image..." Clicked="OnPickDesktopPicture" />
            </HorizontalStackLayout>
            <Image x:Name="DesktopPicPreview" HeightRequest="120" Aspect="AspectFit" HorizontalOptions="Start" />

            <Label Text="Paint Init Image URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="PaintInitImageEntry" Placeholder="media/image/picture.png" HorizontalOptions="FillAndExpand" />
                <Button Text="Browse Image..." Clicked="OnPickPaintImage" />
            </HorizontalStackLayout>
            <Image x:Name="PaintInitPreview" HeightRequest="120" Aspect="AspectFit" HorizontalOptions="Start" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
