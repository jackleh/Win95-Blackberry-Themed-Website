<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.ProjectsPage"
             Title="Projects">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16" x:Name="RootLayout">

            <Label Text="Projects" FontSize="22" FontAttributes="Bold" />
            <Label Text="Portfolio projects displayed on the site." Opacity="0.6" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" BackgroundColor="Green" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Button Text="+ Add Project" Clicked="OnAddProject" BackgroundColor="#2B0B98" />

            <VerticalStackLayout x:Name="ProjectsList" Spacing="20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
