<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.AboutMePage"
             Title="About Me">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="About Me" FontSize="22" FontAttributes="Bold" />
            <Label Text="Professional summary, skills, languages, and location." Opacity="0.6" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" BackgroundColor="Green" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Summary" FontAttributes="Bold" />
            <Editor x:Name="SummaryEditor" Placeholder="Professional summary..." AutoSize="TextChanges" MinimumHeightRequest="100" />

            <Label Text="Location" FontAttributes="Bold" />
            <Entry x:Name="LocationEntry" Placeholder="City, State" />

            <Label Text="GitHub URL" FontAttributes="Bold" />
            <Entry x:Name="GithubEntry" Placeholder="https://github.com/..." Keyboard="Url" />

            <!-- Skills -->
            <Label Text="Skills" FontSize="18" FontAttributes="Bold" />
            <Label Text="One skill per line." Opacity="0.6" />
            <Editor x:Name="SkillsEditor" Placeholder="Skill 1&#10;Skill 2&#10;..." AutoSize="TextChanges" MinimumHeightRequest="120" />

            <!-- Languages -->
            <Label Text="Languages" FontSize="18" FontAttributes="Bold" />
            <Label Text="One language per line." Opacity="0.6" />
            <Editor x:Name="LanguagesEditor" Placeholder="C#&#10;JavaScript&#10;..." AutoSize="TextChanges" MinimumHeightRequest="80" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
