<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebsiteBuilder.Pages.ContactPage"
             Title="Contact">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="Contact" FontSize="22" FontAttributes="Bold" />
            <Label Text="Contact note and call-to-action lines shown on the site." Opacity="0.6" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Website Folder" Clicked="OnOpenFolder" />
                <Button Text="Save All" Clicked="OnSaveAll" BackgroundColor="Green" />
                <Label x:Name="StatusLabel" VerticalOptions="Center" TextColor="Gray" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Contact Note" FontAttributes="Bold" />
            <Entry x:Name="ContactNoteEntry" Placeholder="Best way to reach me: ..." />

            <Label Text="Call to Action Lines" FontSize="18" FontAttributes="Bold" />
            <Label Text="One line per row." Opacity="0.6" />
            <Editor x:Name="CtaEditor" Placeholder="Feel free to reach out..." AutoSize="TextChanges" MinimumHeightRequest="100" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
