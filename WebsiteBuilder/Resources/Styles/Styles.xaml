<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ════════════════════════════════════════════════════════════════
         Windows 95 theme.
         There is no dark variant — Win95 had exactly one look — so colors
         are hardcoded (no AppThemeBinding) to keep text readable no matter
         what theme the host OS is running. "Tahoma" is a Windows system
         font, so it resolves on the WinUI target without bundling.
         ════════════════════════════════════════════════════════════════ -->

    <!-- Every page is a silver Win95 "window" body. The Shell nav bar is hidden;
         each page draws its own navy header so it matches the flyout header exactly. -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Silver}" />
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
    </Style>

    <!-- Shell: navy title/nav bar, white foreground (icons/back arrow),
         silver flyout. ForegroundColor MUST be light or it vanishes on navy. -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Win95Navy}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Win95Highlight}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource Win95Highlight}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource Win95Text}" />
        <Setter Property="Shell.FlyoutBackgroundColor" Value="{StaticResource Win95Silver}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Win95Text}" />
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Inputs are sunken white fields, classic Win95. -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Win95Text}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Field}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinimumHeightRequest" Value="36" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource Win95Text}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Field}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Win95 push button: silver face, black text, square corners, hard edge.
         (MAUI only supports a single BorderColor, so the shadow edge is used;
         the raised two-tone bevel of real Win95 isn't expressible here.) -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource Win95Text}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Silver}" />
        <Setter Property="BorderColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinimumHeightRequest" Value="32" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- Win95 group box: silver panel, etched border, square corners,
         with a hard drop shadow to read as a floating window panel. -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Silver}" />
        <Setter Property="BorderColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Shadow">
            <Shadow Brush="Black" Offset="2,2" Radius="0" Opacity="0.5" />
        </Setter>
    </Style>

    <!-- Pickers and switches in Win95 navy/silver. -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource Win95Text}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Win95Field}" />
        <Setter Property="TitleColor" Value="{StaticResource Win95Shadow}" />
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Default thumb stays (visible on silver); only tint the "on" track blue. -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Blue100Accent}" />
    </Style>

    <!-- Shared title/subtitle styling so the flyout header and each page's
         nav-bar TitleView line up on identical baselines. -->
    <Style x:Key="NavTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="NavSubtitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Tahoma" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="Opacity" Value="0.85" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

</ResourceDictionary>
