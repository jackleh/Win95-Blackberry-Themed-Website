@page "/"
@using PortfolioWebsite.Models
@using PortfolioWebsite.ViewModels
@using PortfolioWebsite.Components.EasterEgg
@inject BaseViewModel BaseViewModel

<PageTitle>Jack Lehman</PageTitle>

@if (_ready)
{
    <Win95Desktop Mode="EasterEggMode.Standalone" OnExit="@(() => { })" />
}

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        await BaseViewModel.InitializeAsync();
        _ready = true;
    }
}
