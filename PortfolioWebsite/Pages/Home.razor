    {
        if ((bool)!EasterEggsEnabled) return;

        /* todo you keep going and exhaust all your warnings, minimize the window and show a windows 95 desktop with
         * the lain_phone playing in a unclosable desktop window with the navi computer as the BG. after that video plays
         * play the lain_vhs, then lain_falling_dance video, after which it will close.
         *
         * there will also have a cmd on the desktop and one in the fake task bar on the desktop which will
         * restore the webpage back to its original state.
         */
        throw new NotImplementedException();
    }
}