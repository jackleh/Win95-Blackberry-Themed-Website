@inject IJSRuntime JS
@inject HttpClient Http
@inject BaseViewModel BaseViewModel
@implements IDisposable

<div class="win95-overlay" @onclick="CloseStartMenu">
    <div class="win95-desktop" style="background-image: url('@_wallpaperUrl')">

        <div class="desktop-icons">
            <div class="desktop-icon" @ondblclick="OpenResumeWindow">
                <div class="icon-img txt-icon"></div>
                <div class="icon-label">resume.md</div>
            </div>

            <div class="desktop-icon" @ondblclick="OpenProjectsWindow">
                <div class="icon-img txt-icon"></div>
                <div class="icon-label">projects.txt</div>
            </div>

            <div class="desktop-icon" @ondblclick="OpenContactWindow">
                <div class="icon-img txt-icon"></div>
                <div class="icon-label">contact.txt</div>
            </div>
        </div>

        @if (_videoOpen)
        {
            <div class="win95-window video-window @(_videoMinimized ? "minimized" : "") @(_videoMaximized ? "maximized" : "")"
                 id="videoWindow"
                 style="z-index:@Z("video")"
                 @onmousedown="() => Raise("video")">
                <div class="win95-titlebar" id="videoTitleBar">
                    <span class="win95-title">@_currentVideoTitle</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="MinimizeVideo">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="ToggleMaximizeVideo">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="CloseVideoWindow">×</button>
                    </div>
                </div>
                <div class="win95-body video-body">
                    <video @ref="_videoRef"
                           src="@_currentVideoSrc"
                           autoplay
                           @onended="OnVideoEnded"
                           style="width:100%;height:100%;display:block;background:#000;">
                    </video>
                </div>
                <div class="video-controls">
                    <button class="video-ctrl-btn" @onclick="VideoPrev" disabled="@(_videoIndex == 0)" title="Previous">◄◄</button>
                    <button class="video-ctrl-btn" @onclick="ToggleVideoPause" title="@(_videoPaused ? "Play" : "Pause")">@(_videoPaused ? "▶" : "⏸")</button>
                    <button class="video-ctrl-btn" @onclick="VideoNext" disabled="@(_videoIndex == _videoTitles.Length - 1)" title="Next">►►</button>
                    <span class="video-track-label">@(_videoIndex + 1) / @_videoTitles.Length</span>
                    <span class="video-vol-icon" @onclick="ToggleVideoMute" title="@(_videoMuted ? "Unmute" : "Mute")">@(_videoMuted ? "🔇" : "🔊")</span>
                    <input type="range" class="video-volume-slider" min="0" max="100" value="@_videoVolume" @oninput="SetVideoVolume" title="Volume" />
                </div>
            </div>
        }

        @if (_cmdOpen)
        {
            <div class="win95-window cmd-window @(_cmdMinimized ? "minimized" : "") @(_cmdMaximized ? "maximized" : "")"
                 id="cmdWindow"
                 style="z-index:@Z("cmd")"
                 @onmousedown="() => Raise("cmd")"
                 @onclick="FocusCmdInput">
                <div class="win95-titlebar" id="cmdTitleBar">
                    <span class="win95-title">C:\COPLAND\system32\cmd.exe</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="MinimizeCmd">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="ToggleMaximizeCmd">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="CloseCmd">×</button>
                    </div>
                </div>
                <div class="win95-body cmd-body" id="cmdBody">
                    <p>Copland OS Enterprise [Version 8.00.001]</p>
                    <p>(C) Copyright Copland Corp 1994-1996.</p>
                    @foreach (var line in _cmdHistory)
                    {
                        <p>@line</p>
                    }
                    <p class="cmd-prompt-line">@_cwd&gt;&nbsp;<input @ref="_cmdInputRef"
                        class="cmd-input"
                        value="@_cmdInput"
                        @oninput="e => _cmdInput = e.Value?.ToString() ?? string.Empty"
                        @onkeydown="OnCmdKeyDown"
                        maxlength="100"
                        autocomplete="off"
                        spellcheck="false" /></p>
                </div>
            </div>
        }

        @if (_projectsOpen)
        {
            <div class="win95-window txtfile-window projects-window-default @(_projectsMinimized ? "minimized" : "") @(_projectsMaximized ? "maximized" : "")"
                 id="projectsWindow"
                 style="z-index:@Z("projects")"
                 @onmousedown="() => Raise("projects")">
                <div class="win95-titlebar" id="projectsTitleBar">
                    <span class="win95-title">projects.txt - Notepad</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _projectsMinimized = true">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _projectsMaximized = !_projectsMaximized">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _projectsOpen = false">×</button>
                    </div>
                </div>
                <div class="notepad-menubar">
                    <span class="notepad-menu-item">File</span>
                    <span class="notepad-menu-item">Edit</span>
                    <span class="notepad-menu-item">Format</span>
                    <span class="notepad-menu-item">View</span>
                    <span class="notepad-menu-item">Help</span>
                </div>
                <div class="notepad-body">
                    <pre class="txtfile-content">@ProjectsText</pre>
                </div>
            </div>
        }

        @if (_resumeOpen)
        {
            <div class="win95-window txtfile-window resume-window-default @(_resumeMinimized ? "minimized" : "") @(_resumeMaximized ? "maximized" : "")"
                 id="resumeWindow"
                 style="z-index:@Z("resume")"
                 @onmousedown="() => Raise("resume")">
                <div class="win95-titlebar" id="resumeTitleBar">
                    <span class="win95-title">resume.md</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _resumeMinimized = true">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _resumeMaximized = !_resumeMaximized">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _resumeOpen = false">×</button>
                    </div>
                </div>
                <div class="notepad-menubar">
                    <span class="notepad-menu-item">File</span>
                    <span class="notepad-menu-item">View</span>
                    <span class="notepad-menu-item">Help</span>
                </div>
                <div class="notepad-body resume-md-body">
                    @{
                        var resume   = BaseViewModel.Resume;
                        var person   = BaseViewModel.Person;
                        var linkedin = SafeHref(person?.LinkedinUrl);
                        var github   = SafeHref(BaseViewModel.AboutMe?.GithubUrl);
                    }
                    <div class="resume-doc">
                        <h1>@(person?.Name)</h1>
                        <p class="resume-tagline">@(resume?.Tagline)</p>
                        <p class="resume-meta">
                            @resume?.Email &nbsp;&middot;&nbsp;
                            @resume?.Phone &nbsp;&middot;&nbsp;
                            @resume?.Location &nbsp;&middot;&nbsp;
                            <a href="@linkedin" target="_blank" rel="noopener noreferrer">LinkedIn</a> &nbsp;&middot;&nbsp;
                            <a href="@github" target="_blank" rel="noopener noreferrer">GitHub</a>
                        </p>
                        <hr/>

                        <h2>About</h2>
                        <p>@(resume?.About)</p>

                        @if (resume?.Companies is { Count: > 0 })
                        {
                            <h2>Job History</h2>
                            @foreach (var company in resume.Companies)
                            {
                                <h3>@company.Name</h3>
                                @foreach (var role in company.Roles)
                                {
                                    <p class="resume-role">
                                        @role.Title &nbsp;&middot;&nbsp; <span class="resume-date">@role.Dates</span>
                                    </p>
                                    <ul>
                                        @foreach (var bullet in role.Bullets)
                                        {
                                            <li>@bullet</li>
                                        }
                                    </ul>
                                }
                            }
                        }

                        @if (resume?.SkillGroups is { Count: > 0 })
                        {
                            <h2>Skills</h2>
                            @foreach (var group in resume.SkillGroups)
                            {
                                <p class="resume-role">@group.Heading</p>
                                <ul>
                                    @foreach (var item in group.Items)
                                    {
                                        <li><strong>@item.Label</strong> &mdash; @item.Detail</li>
                                    }
                                </ul>
                            }
                        }

                        @if (resume?.Education is { Count: > 0 })
                        {
                            <h2>Education</h2>
                            @foreach (var ed in resume.Education)
                            {
                                <p>@ed.School &mdash; @ed.Degree &nbsp;&middot;&nbsp; @ed.Year</p>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        @if (_contactOpen)
        {
            <div class="win95-window txtfile-window contact-window-default @(_contactMinimized ? "minimized" : "") @(_contactMaximized ? "maximized" : "")"
                 id="contactWindow"
                 style="z-index:@Z("contact")"
                 @onmousedown="() => Raise("contact")">
                <div class="win95-titlebar" id="contactTitleBar">
                    <span class="win95-title">contact.txt - Notepad</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _contactMinimized = true">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _contactMaximized = !_contactMaximized">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="() => _contactOpen = false">×</button>
                    </div>
                </div>
                <div class="notepad-menubar">
                    <span class="notepad-menu-item">File</span>
                    <span class="notepad-menu-item">Edit</span>
                    <span class="notepad-menu-item">Format</span>
                    <span class="notepad-menu-item">View</span>
                    <span class="notepad-menu-item">Help</span>
                </div>
                <div class="notepad-body">
                    <pre class="txtfile-content">@ContactText</pre>
                </div>
            </div>
        }

        @if (_notepadOpen)
        {
            <div class="win95-window notepad-window @(_notepadMinimized ? "minimized" : "") @(_notepadMaximized ? "maximized" : "")"
                 id="notepadWindow"
                 style="z-index:@Z("notepad")"
                 @onmousedown="() => Raise("notepad")">
                <div class="win95-titlebar" id="notepadTitleBar">
                    <span class="win95-title">Untitled - Notepad</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="MinimizeNotepad">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="ToggleMaximizeNotepad">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="CloseNotepad">×</button>
                    </div>
                </div>
                <div class="notepad-body">
                    <textarea class="notepad-textarea"
                              @bind="_notepadText"
                              @bind:event="oninput"
                              spellcheck="false"></textarea>
                </div>
            </div>
        }

        @if (_paintOpen)
        {
            <div class="win95-window paint-window @(_paintMinimized ? "minimized" : "") @(_paintMaximized ? "maximized" : "")"
                 id="paintWindow"
                 style="z-index:@Z("paint")"
                 @onmousedown="() => Raise("paint")">
                <div class="win95-titlebar" id="paintTitleBar">
                    <span class="win95-title">untitled - Paint</span>
                    <div class="win95-controls">
                        <button class="win95-btn" @onclick:stopPropagation @onclick="MinimizePaint">_</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="ToggleMaximizePaint">□</button>
                        <button class="win95-btn" @onclick:stopPropagation @onclick="ClosePaint">×</button>
                    </div>
                </div>
                <div class="paint-main">
                    <div class="paint-toolbar">
                        <div class="paint-tools-grid">
                            <button class="paint-tool @(_paintTool == "draw"  ? "active" : "")" title="Pencil"  @onclick='() => SetPaintTool("draw")'>✏</button>
                            <button class="paint-tool @(_paintTool == "erase" ? "active" : "")" title="Eraser"  @onclick='() => SetPaintTool("erase")'>◻</button>
                            <button class="paint-tool @(_paintTool == "fill"  ? "active" : "")" title="Fill"    @onclick='() => SetPaintTool("fill")'>◈</button>
                            <div class="paint-tool-gap"></div>
                        </div>
                        <div class="paint-toolbar-sep"></div>
                        <div class="paint-color-display">
                            <div class="paint-fg-color" style="background-color:@_paintColor"></div>
                        </div>
                        <div class="paint-toolbar-sep"></div>
                        <div class="paint-sizes">
                            <button class="paint-size-btn @(_paintSize == 2  ? "active" : "")" @onclick='() => SetPaintSize(2)' ><span class="pdot pdot-sm"></span></button>
                            <button class="paint-size-btn @(_paintSize == 5  ? "active" : "")" @onclick='() => SetPaintSize(5)' ><span class="pdot pdot-md"></span></button>
                            <button class="paint-size-btn @(_paintSize == 10 ? "active" : "")" @onclick='() => SetPaintSize(10)'><span class="pdot pdot-lg"></span></button>
                        </div>
                    </div>
                    <div class="paint-canvas-area">
                        <canvas id="paintCanvas" width="480" height="360" class="paint-canvas"></canvas>
                    </div>
                </div>
                <div class="paint-palette">
                    <div class="paint-current-swatch" style="background-color:@_paintColor" title="Current color"></div>
                    <div class="paint-palette-sep"></div>
                    @foreach (var col in _paletteColors)
                    {
                        var c = col;
                        <div class="paint-palette-color @(_paintColor == c ? "selected" : "")"
                             style="background-color:@c"
                             @onclick='() => SetPaintColor(c)'
                             title="@c"></div>
                    }
                </div>
            </div>
        }
    </div>

    @if (_startMenuOpen)
    {
        <div class="win95-start-menu" @onclick:stopPropagation>
            <div class="start-menu-sidebar">Copland OS</div>
            <div class="start-menu-items">
                <div class="start-menu-item" @onclick="OpenPaintWindow">
                    <span class="start-menu-icon">🖌</span>
                    <span>paint.exe</span>
                </div>
                <div class="start-menu-item" @onclick="OpenNotepadWindow">
                    <span class="start-menu-icon">📝</span>
                    <span>notepad.exe</span>
                </div>
                <div class="start-menu-divider"></div>
                @for (int i = 0; i < _videoTitles.Length; i++)
                {
                    var idx = i;
                    <div class="start-menu-item" @onclick="() => OpenVideoFromMenu(idx)">
                        <span class="start-menu-icon">▶</span>
                        <span>@_videoTitles[idx]</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="win95-taskbar">
        <button class="win95-start-btn @(_startMenuOpen ? "active" : "")"
                @onclick="ToggleStartMenu"
                @onclick:stopPropagation>
            Menu
        </button>
        <div class="taskbar-divider"></div>
        <div class="taskbar-windows">
            @if (_projectsOpen)
            {
                <div class="taskbar-item @(!_projectsMinimized ? "active" : "")"
                     @onclick="ToggleProjectsFromTaskbar">
                    projects.txt
                </div>
            }
            @if (_resumeOpen)
            {
                <div class="taskbar-item @(!_resumeMinimized ? "active" : "")"
                     @onclick="ToggleResumeFromTaskbar">
                    resume.md
                </div>
            }
            @if (_contactOpen)
            {
                <div class="taskbar-item @(!_contactMinimized ? "active" : "")"
                     @onclick="ToggleContactFromTaskbar">
                    contact.txt
                </div>
            }
            @if (_videoOpen)
            {
                <div class="taskbar-item @(!_videoMinimized ? "active" : "")"
                     @onclick="ToggleVideoFromTaskbar">
                    @_currentVideoTitle
                </div>
            }
            @if (_cmdOpen)
            {
                <div class="taskbar-item @(!_cmdMinimized ? "active" : "")"
                     @onclick="ToggleCmdFromTaskbar">
                    cmd.exe
                </div>
            }
            @if (_notepadOpen)
            {
                <div class="taskbar-item @(!_notepadMinimized ? "active" : "")"
                     @onclick="ToggleNotepadFromTaskbar">
                    Untitled - Notepad
                </div>
            }
            @if (_paintOpen)
            {
                <div class="taskbar-item @(!_paintMinimized ? "active" : "")"
                     @onclick="TogglePaintFromTaskbar">
                    untitled - Paint
                </div>
            }
        </div>
        <div class="taskbar-cmd-btn" @onclick="OpenCmdWindow" title="Open CMD">
            <span>C:\</span>
        </div>
        <div class="taskbar-clock">@_clock</div>
    </div>
</div>

@code {
    private string _wallpaperUrl => BaseViewModel.SiteConfig?.EasterEggDesktopPictureUrl ?? string.Empty;

    // Z-order tracking — each window gets a stable z-index; clicking raises it.
    private readonly Dictionary<string, int> _windowZ = new();
    private int _zCounter = 100;
    private int Z(string key) => _windowZ.TryGetValue(key, out var z) ? z : (_windowZ[key] = ++_zCounter);
    private void Raise(string key) => _windowZ[key] = ++_zCounter;

    // Clock
    private string _clock = string.Empty;
    private System.Timers.Timer? _clockTimer;
    private volatile bool _disposed;

    // Video
    private bool _videoOpen;
    private bool _videoMinimized;
    private bool _videoMaximized;
    private bool _videoPaused;
    private bool _videoMuted;
    private int  _videoIndex;
    private int  _videoVolume    = 100;
    private int  _videoVolumePre = 100;
    private bool _videoNeedsInit;
    private bool _videoVolumeNeedsSync;
    private ElementReference _videoRef;
    private readonly string[] _videoTitles = ["lain_phone.mp4", "lain_vhs.mp4", "lain_falling_dance.mp4"];

    // CMD
    private bool _cmdOpen;
    private bool _cmdMinimized;
    private bool _cmdMaximized;
    private bool _cmdNeedsInit;
    private bool _cmdShouldFocus;
    private bool _cmdShouldScroll;
    private string _cmdInput = string.Empty;
    private readonly List<string> _cmdHistory = new();
    private ElementReference _cmdInputRef;

    // Start menu
    private bool _startMenuOpen;

    // Content file windows
    private bool _projectsOpen, _projectsMinimized, _projectsMaximized, _projectsNeedsInit;
    private bool _resumeOpen,   _resumeMinimized,   _resumeMaximized,   _resumeNeedsInit;
    private bool _contactOpen,  _contactMinimized,  _contactMaximized,  _contactNeedsInit;

    // Notepad
    private bool _notepadOpen, _notepadMinimized, _notepadMaximized, _notepadNeedsInit;
    private string _notepadText = string.Empty;

    // Paint
    private bool _paintOpen, _paintMinimized, _paintMaximized, _paintNeedsInit;
    private string _paintTool  = "draw";
    private string _paintColor = "#000000";
    private int    _paintSize  = 3;

    private readonly string[] _paletteColors =
    [
        "#000000","#808080","#800000","#808000","#008000","#008080","#000080","#800080",
        "#c0c0c0","#ffffff","#ff0000","#ffff00","#00ff00","#00ffff","#0000ff","#ff00ff",
        "#ff8040","#804000","#ffff80","#80ff80"
    ];

    private string _currentVideoTitle => _videoIndex < _videoTitles.Length
        ? _videoTitles[_videoIndex]
        : string.Empty;

    private string _currentVideoSrc => _videoIndex switch
    {
        0 => BaseViewModel.SiteConfig?.EasterEggVideo1Url ?? string.Empty,
        1 => BaseViewModel.SiteConfig?.EasterEggVideo2Url ?? string.Empty,
        2 => BaseViewModel.SiteConfig?.EasterEggVideo3Url ?? string.Empty,
        _ => string.Empty
    };

    protected override void OnInitialized()
    {
        _clock = DateTime.Now.ToString("HH:mm");

        // 30s tick is plenty for an HH:mm display.
        _clockTimer = new System.Timers.Timer(30_000);
        _clockTimer.Elapsed += async (_, _) =>
        {
            if (_disposed) return;
            try
            {
                var next = DateTime.Now.ToString("HH:mm");
                if (next == _clock) return;
                _clock = next;
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException) { /* component torn down */ }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Clock tick failed: {ex.Message}");
            }
        };
        _clockTimer.AutoReset = true;
        _clockTimer.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Each window's drag/resize is initialized once after it opens, gated by a *NeedsInit flag.
        if (_videoNeedsInit && _videoOpen)
        {
            _videoNeedsInit = false;
            _videoVolumeNeedsSync = true;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "videoWindow", "videoTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "videoWindow");
        }

        if (_videoVolumeNeedsSync && _videoOpen && !_videoMinimized)
        {
            _videoVolumeNeedsSync = false;
            try { await JS.InvokeVoidAsync("dragHelper.videoSetVolume", _videoRef, _videoVolume / 100.0); } catch { }
        }

        if (_cmdNeedsInit && _cmdOpen)
        {
            _cmdNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "cmdWindow", "cmdTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "cmdWindow");
        }

        if (_projectsNeedsInit && _projectsOpen)
        {
            _projectsNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "projectsWindow", "projectsTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "projectsWindow");
        }

        if (_resumeNeedsInit && _resumeOpen)
        {
            _resumeNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "resumeWindow", "resumeTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "resumeWindow");
        }

        if (_contactNeedsInit && _contactOpen)
        {
            _contactNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "contactWindow", "contactTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "contactWindow");
        }

        if (_notepadNeedsInit && _notepadOpen)
        {
            _notepadNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "notepadWindow", "notepadTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "notepadWindow");
        }

        if (_paintNeedsInit && _paintOpen)
        {
            _paintNeedsInit = false;
            await JS.InvokeVoidAsync("dragHelper.enableDrag",   "paintWindow", "paintTitleBar");
            await JS.InvokeVoidAsync("dragHelper.enableResize", "paintWindow");
            await JS.InvokeVoidAsync("paintHelper.init", "paintCanvas", _paintInitImageUrl);
        }

        if (_cmdShouldScroll)
        {
            _cmdShouldScroll = false;
            try { await JS.InvokeVoidAsync("dragHelper.scrollToBottom", "cmdBody"); } catch { }
        }

        if (_cmdShouldFocus)
        {
            _cmdShouldFocus = false;
            try { await _cmdInputRef.FocusAsync(); } catch { }
        }
    }

    // ── Video ────────────────────────────────────────────────────────────────
    private Task OnVideoEnded()
    {
        _videoIndex++;
        _videoPaused = false;
        if (_videoIndex >= _videoTitles.Length)
            CloseVideoWindow();
        else
            _videoVolumeNeedsSync = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void MinimizeVideo() => _videoMinimized = true;
    private void ToggleMaximizeVideo() => _videoMaximized = !_videoMaximized;
    private void CloseVideoWindow()
    {
        _videoOpen      = false;
        _videoMinimized = false;
        _videoMaximized = false;
        _videoPaused    = false;
        _videoVolume    = 100;
        _videoVolumePre = 100;
        _videoMuted     = false;
    }

    private void VideoPrev()
    {
        if (_videoIndex > 0)
        {
            _videoIndex--;
            _videoPaused = false;
            _videoVolumeNeedsSync = true;
        }
    }

    private void VideoNext()
    {
        _videoIndex++;
        _videoPaused = false;
        if (_videoIndex >= _videoTitles.Length)
            CloseVideoWindow();
        else
            _videoVolumeNeedsSync = true;
    }

    private async Task ToggleVideoPause()
    {
        _videoPaused = !_videoPaused;
        try
        {
            if (_videoPaused)
                await JS.InvokeVoidAsync("dragHelper.videoPause", _videoRef);
            else
                await JS.InvokeVoidAsync("dragHelper.videoPlay", _videoRef);
        }
        catch (Exception ex) { Console.Error.WriteLine($"video toggle failed: {ex.Message}"); }
    }

    private async Task SetVideoVolume(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _videoVolume = v;
            _videoMuted  = v == 0;
            if (v > 0) _videoVolumePre = v;
            try { await JS.InvokeVoidAsync("dragHelper.videoSetVolume", _videoRef, v / 100.0); } catch { }
        }
    }

    private async Task ToggleVideoMute()
    {
        if (_videoMuted)
        {
            _videoMuted  = false;
            _videoVolume = _videoVolumePre > 0 ? _videoVolumePre : 100;
        }
        else
        {
            _videoVolumePre = _videoVolume > 0 ? _videoVolume : 100;
            _videoMuted     = true;
            _videoVolume    = 0;
        }
        try { await JS.InvokeVoidAsync("dragHelper.videoSetVolume", _videoRef, _videoVolume / 100.0); } catch { }
    }

    // ── CMD ──────────────────────────────────────────────────────────────────
    private void OpenCmdWindow()
    {
