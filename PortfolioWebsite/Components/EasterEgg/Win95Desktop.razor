        _cmdInput = string.Empty;
        _cmdHistory.Clear();
    }

    private async Task FocusCmdInput()
    {
        try { await _cmdInputRef.FocusAsync(); } catch { }
    }

    private async Task OnCmdKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;

        var raw     = _cmdInput;
        var trimmed = raw.Trim();
        _cmdHistory.Add($"{_cwd}> {raw}");
        _cmdInput = string.Empty;

        if (trimmed.Length > 0)
        {
            // Normalize no-space cd variants: cd.. → cd ..   cd\ → cd \   cd\folder → cd \folder
            var normalized = trimmed;
            if (normalized.Length >= 3 && normalized[..2].Equals("cd", StringComparison.OrdinalIgnoreCase) && normalized[2] != ' ')
                normalized = "cd " + normalized[2..];

            var spaceIdx = normalized.IndexOf(' ');
            var verb = (spaceIdx < 0 ? normalized : normalized[..spaceIdx]).ToLower();
            var arg  = spaceIdx < 0 ? "" : normalized[(spaceIdx + 1)..].Trim();

            switch (verb)
            {
                case "cls":
                    _cmdHistory.Clear();
                    _projectsOpen = _resumeOpen = _contactOpen = _notepadOpen = _paintOpen = false;
                    _videoSequenceActive = false;
                    break;
                case "ver":
                    _cmdHistory.Add(OsVersion);
                    break;
                case "help":
                    _cmdHistory.Add("Available commands:");
                    _cmdHistory.Add("  CLS      Clear screen and close all windows");
                    _cmdHistory.Add("  DIR      List directory contents");
                    _cmdHistory.Add("  CD       Change directory  (CD .. / CD <folder>)");
                    _cmdHistory.Add("  VER      Display OS version");
                    _cmdHistory.Add("  <file>   Open a file");
                    break;
                case "dir":
                    foreach (var line in CmdDir())
                        _cmdHistory.Add(line);
                    break;
                case "cd":
                    CmdCd(arg);
                    break;
                default:
                    foreach (var line in await CmdOpen(trimmed))
                        _cmdHistory.Add(line);
                    break;
            }
        }

        _cmdShouldFocus  = true;
        _cmdShouldScroll = true;
    }

