<div class="section-wrapper">
    <div class="section-header">// view-resume</div>

    <div class="resume-container">
        <p class="resume-hint">
            <span class="prompt">$</span> open resume.pdf
        </p>

        <div class="resume-actions">
            <a class="resume-btn" href="media/resume.pdf" target="_blank">
                <span class="btn-icon">↗</span> open in browser
            </a>
            <a class="resume-btn resume-btn-secondary" href="media/resume.pdf" download>
                <span class="btn-icon">↓</span> download pdf
            </a>
        </div>

        <p class="resume-note">
            // place your resume PDF at <span class="path">wwwroot/media/resume.pdf</span>
        </p>
    </div>
</div>

